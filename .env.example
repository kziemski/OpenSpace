# OpenSpace Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# API Keys (Required)
# ===========================================

# Anthropic API key for Claude models
ANTHROPIC_API_KEY=

# OpenAI API key for GPT models
OPENAI_API_KEY=

# OpenRouter API key for model routing
OPENROUTER_API_KEY=

# OpenSpace cloud features API key (optional)
OPENSPACE_API_KEY=

# ===========================================
# Docker Service Ports
# ===========================================

# Dashboard API server port (default: 7788)
DASHBOARD_PORT=7788

# Local server port (default: 5000)
LOCAL_SERVER_PORT=5000

# Frontend development server port (default: 3789)
FRONTEND_PORT=3789

# ===========================================
# Optional Configuration
# ===========================================

# Set to "1" to enable debug mode for Flask servers
DEBUG=0

# Data directory path (relative to project root)
DATA_DIR=./data

# Logs directory path (relative to project root)
LOGS_DIR=./logs
